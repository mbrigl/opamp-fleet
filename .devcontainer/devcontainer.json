{
  "name": "OpAMP Fleet DevContainer",

  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",

  "remoteUser": "vscode",
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind"
  ],

  "shutdownAction": "stopContainer",

  // Runs on the host before the container is created. Ensures the bind-mount source for the agent
  // config exists, so Docker does not auto-create it as a root-owned directory (which breaks
  // credential writes inside the container).
  "initializeCommand": "mkdir -p ${localEnv:HOME}/.claude",

  // DevContainer Features layered on top of the base image. The container intentionally has NO
  // access to the host Docker daemon (no socket mount) — see ADR-0002. Manage the host's containers
  // from a host-side VS Code extension instead (README → "Host container management").
  "features": {
    // GitHub CLI (`gh`) — used by the coding agent for GitHub operations and as the git
    // credential helper. Git writes still require explicit human approval (see AGENTS.md).
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // Rust stable toolchain (rustup + cargo, with rustfmt & clippy) — the project's language
    // toolchain, chosen in ADR-0003. The build chain needs no system protoc (ADR-0004 uses
    // the pure-Rust protox), so no extra system packages are required here.
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "latest",
      "profile": "default"
    }
  },

  "customizations": {
    // VS Code extensions installed inside the container
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "mistralai.mistral-vibe-code",
        "ms-vscode-remote.remote-containers",
        // Rust development: language server, debugger, and Cargo.toml support (ADR-0003).
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "tamasfe.even-better-toml"
      ]
    }
  },

  // The Server serves both the OpAMP HTTP endpoint and the rudimentary UI on this port
  // (ADR-0004 / ADR-0005).
  "forwardPorts": [4320],

  "hostRequirements": {
    "cpus": 2,
    "memory": "8gb",
    "storage": "32gb"
  }
}
