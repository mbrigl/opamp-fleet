{
  // Build tasks used by the launch configurations (see launch.json).
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo build",
      "type": "cargo",
      "command": "build",
      "problemMatcher": ["$rustc"],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "cargo test",
      "type": "cargo",
      "command": "test",
      "args": ["--workspace"],
      "problemMatcher": ["$rustc"],
      "group": { "kind": "test", "isDefault": true }
    }
  ]
}
