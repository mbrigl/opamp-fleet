{
  // Enable GitHub Copilot to read AGENTS.md as agent instructions.
  "chat.useAgentsMdFile": true,
  "files.eol": "\n",
  "editor.formatOnSave": true,

  // Manage the *host's* containers from VS Code without mounting the Docker socket into the Dev
  // Container (see ADR-0002): keep the container-management extension on the host (UI) side even
  // when this folder is reopened in the container. Install "Container Tools" in your host VS Code.
  "remote.extensionKind": {
    "ms-azuretools.vscode-containers": ["ui"],
    "ms-azuretools.vscode-docker": ["ui"]
  }
}
